# ============================================
# PLANTILLA DE VARIABLES DE ENTORNO
# ============================================
# Copia este archivo según el entorno:
# - Desarrollo: cp .env.example .env.dev
# - Producción: cp .env.example .env.prod
#
# ⚠️ IMPORTANTE: 
# - .env.dev y .env.prod están en .gitignore
# - NO subas credenciales al repositorio
# - Cambia las contraseñas por defecto en producción

# ============================================
# Configuración de MongoDB
# ============================================
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=admin123
MONGO_DATABASE=manga_db
MONGO_PORT=27017

# ============================================
# Configuración del Servidor Spring Boot
# ============================================
SERVER_PORT=8080
SPRING_APPLICATION_NAME=server
SPRINGDOC_SWAGGER_UI_PATH=/api/docs
# Para desarrollo usar: SPRING_PROFILES_ACTIVE=dev
# Para producción usar: SPRING_PROFILES_ACTIVE=docker
SPRING_PROFILES_ACTIVE=docker

# ============================================
# Configuración de Desarrollo
# ============================================
DEBUG_PORT=5005
# Para desarrollo: true
# Para producción: false
SPRING_DEVTOOLS_RESTART_ENABLED=true
SPRING_DEVTOOLS_LIVERELOAD_ENABLED=true

# ============================================
# Configuración de Red
# ============================================
MONGO_SERVICE_NAME=mongodb
SERVER_SERVICE_NAME=server
